<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             x:Class="DoubleDashScore.Views.ApiKeySettingsPage"
             x:DataType="vm:ApiKeySettingsViewModel"
             Title="Inställningar">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Label Text="Anthropic API-nyckel"
                   FontAttributes="Bold"
                   FontSize="16" />

            <Label Text="Används för OCR via Claude Vision. Lagras säkert i enhetens nyckelring."
                   FontSize="13"
                   Opacity="0.75" />

            <Label Text="Status:" FontAttributes="Bold" Margin="0,12,0,0" />
            <Label Text="{Binding CurrentStatus}" FontSize="14" />

            <Label Text="Ange nyckel:" FontAttributes="Bold" Margin="0,12,0,0" />
            <Entry Text="{Binding EntryText, Mode=TwoWay}"
                   IsPassword="True"
                   Placeholder="sk-ant-..."
                   Keyboard="Default" />

            <HorizontalStackLayout Spacing="12" Margin="0,12,0,0">
                <Button Text="Spara" Command="{Binding SaveCommand}" />
                <Button Text="Rensa" Command="{Binding ClearCommand}" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Margin="0,12,0,0" />

            <BoxView HeightRequest="1"
                     Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                     Margin="0,16" />

            <Label Text="Auto-backup"
                   FontAttributes="Bold"
                   FontSize="16" />

            <Label Text="Appen tar automatiskt en .db-säkerhetskopia när du ändrar något. Den behåller de 10 senaste."
                   FontSize="13"
                   Opacity="0.75" />

            <Label Text="{Binding BackupLatestLine}" FontSize="14" Margin="0,8,0,0" />
            <Label Text="{Binding BackupCountLine}" FontSize="14" />

            <Button Text="Återställ från auto-backup"
                    Command="{Binding OpenRestoreCommand}"
                    IsEnabled="{Binding HasBackups}"
                    HorizontalOptions="Start"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
