<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             x:Class="DoubleDashScore.Views.EditNotePage"
             x:DataType="vm:EditNoteViewModel"
             Shell.PresentationMode="ModalAnimated"
             Title="Anteckning">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Anteckning"
                   FontFamily="Baloo2Bold"
                   FontSize="16" />

            <!-- AutoSize + VerticalOptions=Start: editorn börjar på en rad och
                 växer med innehållet. Ingen HeightRequest — den skapade ett
                 fixt 140-px-fält där den nativa underlinjen hamnade långt under
                 texten. Underlinjen följer nu direkt under textraderna. -->
            <Editor Text="{Binding Note}"
                    MaxLength="{Binding MaxLength}"
                    AutoSize="TextChanges"
                    VerticalOptions="Start"
                    Placeholder="t.ex. Hos Anna, första kvällen efter sommaren…" />

            <Label Text="{Binding CounterText}"
                   FontSize="12"
                   Opacity="0.6"
                   HorizontalOptions="End" />

            <HorizontalStackLayout Spacing="12" HorizontalOptions="End">
                <Button Text="Avbryt" Command="{Binding CancelCommand}" />
                <Button Text="Spara"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="Black"
                        Command="{Binding SaveCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
