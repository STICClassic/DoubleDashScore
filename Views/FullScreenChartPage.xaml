<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.FullScreenChartPage"
             x:Name="PageRoot"
             x:DataType="vm:FullScreenChartViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#C8C8C8">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <!-- DefaultTrackerTemplate slopad — tooltipens crosshair-linjer +
                 bubbla ersätts av vertikal LineAnnotation + legend-snitten.
                 TrackerChanged-eventet fires fortfarande och fångas av VM:n. -->
            <oxy:PlotView Model="{Binding PlotModel}"
                          BackgroundColor="Transparent">
                <oxy:PlotView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding TogglePlotTapCommand}" />
                </oxy:PlotView.GestureRecognizers>
            </oxy:PlotView>

            <Button x:Name="ResetButton"
                    Text="↺"
                    Command="{Binding ResetZoomCommand}"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#222222"
                    BackgroundColor="#80FFFFFF"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    CornerRadius="20"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="16,16,0,0" />

            <Button x:Name="CloseButton"
                    Text="✕"
                    Command="{Binding CloseCommand}"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="#222222"
                    BackgroundColor="#80FFFFFF"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    CornerRadius="20"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,16,16,0" />
        </Grid>

        <!-- Legend med snitt: "Kväll N" i siffer-radens vänsterkant, fyra
             spelare med namn (rad 1) + snitt (rad 2). Synkar med vanlig graf
             via ChartTransferStore (NightSlices + SelectedNightIndex). -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="8"
              Margin="0,2,0,6">
            <Label Grid.Column="0"
                   Text="{Binding SelectedNightLabel}"
                   TextColor="#222222"
                   FontFamily="Baloo2Bold"
                   FontSize="13"
                   VerticalOptions="End"
                   Padding="8,0,0,8"
                   IsVisible="{Binding HasSelectedNight}" />

            <CollectionView Grid.Column="1"
                            ItemsSource="{Binding LegendItems}"
                            ItemsLayout="HorizontalList"
                            SelectionMode="None"
                            HorizontalOptions="Center">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlayerLegendItem">
                        <Grid Padding="10,4" RowDefinitions="Auto,Auto" RowSpacing="2">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                            <HorizontalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center">
                                <BoxView WidthRequest="14"
                                         HeightRequest="14"
                                         Color="{Binding Color}"
                                         VerticalOptions="Center"
                                         Opacity="{Binding NameOpacity}" />
                                <Label Text="{Binding Name}"
                                       FontFamily="Baloo2"
                                       FontSize="13"
                                       TextColor="#222222"
                                       VerticalOptions="Center"
                                       Opacity="{Binding NameOpacity}"
                                       TextDecorations="{Binding NameDecorations}" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1"
                                   Text="{Binding NightAverageDisplay}"
                                   HorizontalOptions="Center"
                                   FontFamily="Baloo2Bold"
                                   FontSize="13"
                                   TextColor="#222222"
                                   Opacity="{Binding NameOpacity}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </Grid>

</ContentPage>
