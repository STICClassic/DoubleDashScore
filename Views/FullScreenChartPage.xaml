<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.FullScreenChartPage"
             x:DataType="vm:FullScreenChartViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#E8E8E8">

    <Grid>
        <oxy:PlotView Model="{Binding PlotModel}"
                      BackgroundColor="Transparent" />

        <Button Text="↺"
                Command="{Binding ResetZoomCommand}"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#222222"
                BackgroundColor="#80FFFFFF"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                CornerRadius="20"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,16,0,0" />

        <Button Text="✕"
                Command="{Binding CloseCommand}"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#222222"
                BackgroundColor="#80FFFFFF"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                CornerRadius="20"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,16,16,0" />
    </Grid>

</ContentPage>
