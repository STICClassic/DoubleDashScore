<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.FullScreenChartPage"
             x:Name="PageRoot"
             x:DataType="vm:FullScreenChartViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#C8C8C8">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <!-- DefaultTrackerTemplate slopad — tooltipens crosshair-linjer +
                 bubbla ersätts av vertikal LineAnnotation + legend-snitten.
                 TrackerChanged-eventet fires fortfarande och fångas av VM:n. -->
            <oxy:PlotView Model="{Binding PlotModel}"
                          BackgroundColor="Transparent">
                <oxy:PlotView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding TogglePlotTapCommand}" />
                </oxy:PlotView.GestureRecognizers>
            </oxy:PlotView>

            <Button x:Name="ResetButton"
                    Text="↺"
                    Command="{Binding ResetZoomCommand}"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#222222"
                    BackgroundColor="#80FFFFFF"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    CornerRadius="20"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="16,16,0,0" />

            <Button x:Name="CloseButton"
                    Text="✕"
                    Command="{Binding CloseCommand}"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="#222222"
                    BackgroundColor="#80FFFFFF"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    CornerRadius="20"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,16,16,0" />
        </Grid>

        <!-- Legend med snitt: "Kväll N" hänger direkt vänster om första
             snittsiffran (8 dp gap), hela gruppen centreras horisontellt. I
             landskap (= denna vy) blir det mer luft kring den centrerade
             gruppen — inget växande glapp mellan rubrik och första siffran.
             BindableLayout istället för CollectionView eftersom HSL+
             CollectionView (HorizontalList) inte rapporterar DesiredSize
             tillförlitligt; vi har alltid 4 spelare så virtualisering ger
             inget. Synkar med vanlig graf via ChartTransferStore
             (NightSlices + SelectedNightIndex). -->
        <HorizontalStackLayout Grid.Row="1"
                               HorizontalOptions="Center"
                               Spacing="8"
                               Margin="0,2,0,6">
            <!-- VerticalOptions="End" + Padding bottom=4 matchar items egna
                 4 dp bottom-padding så rubriken hamnar på samma baslinje som
                 snittsiffrorna (rad 2 i items). "Center" skulle hamna mellan
                 namn-rad och siffer-rad. -->
            <Label Text="{Binding SelectedNightLabel, StringFormat='{0}:'}"
                   TextColor="#222222"
                   FontFamily="Baloo2Bold"
                   FontSize="13"
                   VerticalOptions="End"
                   Padding="0,0,0,4"
                   IsVisible="{Binding HasSelectedNight}" />

            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding LegendItems}"
                                   Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlayerLegendItem">
                        <Grid Padding="10,4" RowDefinitions="Auto,Auto" RowSpacing="2">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                            <HorizontalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center">
                                <BoxView WidthRequest="14"
                                         HeightRequest="14"
                                         Color="{Binding Color}"
                                         VerticalOptions="Center"
                                         Opacity="{Binding NameOpacity}" />
                                <Label Text="{Binding Name}"
                                       FontFamily="Baloo2"
                                       FontSize="13"
                                       TextColor="#222222"
                                       VerticalOptions="Center"
                                       Opacity="{Binding NameOpacity}"
                                       TextDecorations="{Binding NameDecorations}" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1"
                                   Text="{Binding NightAverageDisplay}"
                                   HorizontalOptions="Center"
                                   FontFamily="Baloo2Bold"
                                   FontSize="13"
                                   TextColor="#222222"
                                   Opacity="{Binding NameOpacity}" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
