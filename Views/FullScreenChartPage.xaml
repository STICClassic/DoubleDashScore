<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.FullScreenChartPage"
             x:Name="PageRoot"
             x:DataType="vm:FullScreenChartViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#C8C8C8">

    <!-- Singel Grid-cell: PlotView + ↺/✕-knappar + titel + legend-overlay
         som syskon. MAUI z-orderar efter child-ordning så overlay:n (sist)
         ritas ovanpå. PlotView fyller hela cellen, övriga element
         positioneras med HorizontalOptions/VerticalOptions + Margin. -->
    <Grid>
        <!-- DefaultTrackerTemplate=null så OxyPlot.Maui.Skia inte ritar sin
             gula tooltip vid tap på en datapunkt. Tom ControlTemplate
             kraschar (ShowTracker castar CreateContent()→View med NullRef);
             explicit null hoppar PlotView över rendering helt. PlotModel.
             TrackerChanged fires fortfarande, så VM:n får notifikationen om
             vald kväll. Vår vertikala LineAnnotation + legend-overlayn
             ersätter trackern. -->
        <oxy:PlotView Model="{Binding PlotModel}"
                      BackgroundColor="Transparent"
                      DefaultTrackerTemplate="{x:Null}">
            <oxy:PlotView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding TogglePlotTapCommand}" />
            </oxy:PlotView.GestureRecognizers>
        </oxy:PlotView>

        <!-- ↺ och ✕ båda i top-left-kolumnen (stacked) så top-right-hörnet
             är fritt för legend-overlay:n. Tidigare layout hade ✕ i top-right
             vilket blockerade overlay:n från att klistras i hörnet. -->
        <Button x:Name="ResetButton"
                Text="↺"
                Command="{Binding ResetZoomCommand}"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#222222"
                BackgroundColor="#80FFFFFF"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                CornerRadius="20"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,16,0,0" />

        <Button x:Name="CloseButton"
                Text="✕"
                Command="{Binding CloseCommand}"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#222222"
                BackgroundColor="#80FFFFFF"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                CornerRadius="20"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,72,0,0" />

        <!-- Graf-titel (vänsterjusterad). OxyPlot 2.2.0 saknar Left-
             alignment för PlotModel.Title — VM tömmer Title och reserverar
             32 dp toppstrip via Padding så denna MAUI Label kan ligga där
             utan att kollidera med plot-arean. Margin left=72 så den hamnar
             höger om ↺-knappen. -->
        <Label Text="Kvällssnitt över tid"
               FontFamily="Baloo2Bold"
               FontSize="14"
               TextColor="#222222"
               HorizontalOptions="Start"
               VerticalOptions="Start"
               Margin="72,20,0,0" />

        <!-- Legend-overlay (variant C2) — KLISTRAD i top-right-hörnet
             (Margin "0,8,8,0"). Tidigare Margin top=68 valdes för att duka
             undan ✕-knappen men tryckte ned overlay:n i plot-arean — nu när
             ✕ är flyttad till top-left kan overlay:n gå max upp.

             Bakgrundsfärg #E61A1A1A = ~90 % alpha på #1A1A1A: ger lätt
             transparens utan att tunna ut text.

             Collapse-to-edge: pil-fliken (◄/►) är alltid synlig på vänster-
             kanten. Innehållet (Kväll N: + 4 spelarkolumner) togglas via
             IsVisible bundet till IsLegendExpanded. Border:n krymper då
             till bara fliken + padding och stannar mot högerkanten
             (HorizontalOptions=End). -->
        <Border BackgroundColor="#E61A1A1A"
                StrokeThickness="0"
                Padding="6,8,14,8"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,8,8,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>

            <HorizontalStackLayout Spacing="6">
                <!-- Collapse-flik. Tap-target får extra Padding så den blir
                     bekväm att träffa (12 dp horisontellt totalt). -->
                <Label Text="{Binding LegendCollapseArrow}"
                       TextColor="White"
                       FontFamily="Baloo2Bold"
                       FontSize="14"
                       VerticalOptions="Center"
                       Padding="6,4">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleLegendCollapseCommand}" />
                    </Label.GestureRecognizers>
                </Label>

                <!-- Innehåll: Kväll N: + spelarkolumner. IsVisible bundet
                     till IsLegendExpanded — när false läggs HSL ut med
                     bredd 0 (Maui behandlar IsVisible=false som "gone")
                     och Border:n krymper till bara fliken. -->
                <HorizontalStackLayout Spacing="10"
                                       IsVisible="{Binding IsLegendExpanded}">
                    <!-- VerticalOptions="End" + Padding bottom=2 matchar
                         items egna 2 dp bottom-padding så rubriken hamnar
                         på samma baslinje som snittsiffrorna. -->
                    <Label Text="{Binding SelectedNightLabel, StringFormat='{0}:'}"
                           TextColor="White"
                           FontFamily="Baloo2Bold"
                           FontSize="13"
                           VerticalOptions="End"
                           Padding="0,0,0,2"
                           IsVisible="{Binding HasSelectedNight}" />

                    <!-- BindableLayout istället för CollectionView: HSL+
                         CollectionView rapporterar inte DesiredSize
                         tillförlitligt i MAUI. Vi har alltid 4 spelare så
                         virtualisering ger inget. Ordning kommer från
                         LegendItems → PlotModel.Series → activePlayers
                         sorterade på DisplayOrder = Claes/Aleksi/Jonas/Robin. -->
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding LegendItems}"
                                           Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlayerLegendItem">
                                <Grid Padding="10,2" RowDefinitions="Auto,Auto" RowSpacing="2">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <HorizontalStackLayout Grid.Row="0" Spacing="5" HorizontalOptions="Center">
                                        <!-- BoxView med CornerRadius=5 på 10×10 = filled cirkel.
                                             Färg = spelarens färg (samma som linjen i grafen). -->
                                        <BoxView WidthRequest="10"
                                                 HeightRequest="10"
                                                 CornerRadius="5"
                                                 Color="{Binding Color}"
                                                 VerticalOptions="Center"
                                                 Opacity="{Binding NameOpacity}" />
                                        <Label Text="{Binding Name}"
                                               FontFamily="Baloo2Bold"
                                               FontSize="13"
                                               TextColor="{Binding Color}"
                                               VerticalOptions="Center"
                                               Opacity="{Binding NameOpacity}"
                                               TextDecorations="{Binding NameDecorations}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1"
                                           Text="{Binding NightAverageDisplay}"
                                           HorizontalOptions="Center"
                                           FontFamily="Baloo2Bold"
                                           FontSize="13"
                                           TextColor="White"
                                           Opacity="{Binding NameOpacity}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </HorizontalStackLayout>
        </Border>
    </Grid>

</ContentPage>
