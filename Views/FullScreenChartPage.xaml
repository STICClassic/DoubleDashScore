<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.FullScreenChartPage"
             x:Name="PageRoot"
             x:DataType="vm:FullScreenChartViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#C8C8C8">

    <!-- Singel Grid-cell: PlotView + ↺/✕-knappar + legend-overlay som
         syskon. MAUI z-orderar efter child-ordning så overlay:n (sist)
         ritas ovanpå. PlotView fyller hela cellen, övriga element
         positioneras med HorizontalOptions/VerticalOptions + Margin.
         OxyPlot:s nativa titel ("Kvällssnitt över tid") ritas centrerad
         i toppen av PlotView — overlay:n får täcka den när den är synlig
         (per spec). -->
    <Grid>
        <!-- DefaultTrackerTemplate=null så OxyPlot.Maui.Skia inte ritar sin
             gula tooltip vid tap på en datapunkt. Tom ControlTemplate
             kraschar (ShowTracker castar CreateContent()→View med NullRef);
             explicit null hoppar PlotView över rendering helt. PlotModel.
             TrackerChanged fires fortfarande, så VM:n får notifikationen om
             vald kväll. Vår vertikala LineAnnotation + legend-overlayn
             ersätter trackern. -->
        <oxy:PlotView Model="{Binding PlotModel}"
                      BackgroundColor="Transparent"
                      DefaultTrackerTemplate="{x:Null}">
            <oxy:PlotView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding TogglePlotTapCommand}" />
            </oxy:PlotView.GestureRecognizers>
        </oxy:PlotView>

        <Button x:Name="ResetButton"
                Text="↺"
                Command="{Binding ResetZoomCommand}"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#222222"
                BackgroundColor="#80FFFFFF"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                CornerRadius="20"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,16,0,0" />

        <!-- ✕ tillbaka i top-right (HorizontalOptions=End) — overlay:n är nu
             centrerad horisontellt så hörnen är fria. -->
        <Button x:Name="CloseButton"
                Text="✕"
                Command="{Binding CloseCommand}"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#222222"
                BackgroundColor="#80FFFFFF"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                CornerRadius="20"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,16,16,0" />

        <!-- Legend-overlay som pulldown från övre kanten. Centrerad
             horisontellt (HorizontalOptions=Center), klistrad mot top
             (VerticalOptions=Start, Margin top=0).

             Default: IsLegendExpanded=false → bara pil-fliken (▼) syns
             som en liten chip-form hängande från top-edge. Tap → innehållet
             fälls ut, Border:n växer ner, pilen vänder ▲. Animation
             utelämnad (per PRD:s fallback) — TranslateTo skulle kräva
             känd höjd i förväg vilket är race:y mot layout-passet.

             CornerRadius "0,0,10,10" → toppen kantig (sitter mot skärmens
             top-edge), botten rundad → ser ut som en panel som hänger ner.
             Bakgrund #E61A1A1A = ~90 % alpha på #1A1A1A: lätt transparens
             utan att tunna ut text.

             Tap-hantering: pil-fliken och spelarkolumnerna har egna Tap-
             GestureRecognizers (toggle resp. visibility). Border absorberar
             tap på padding-ytan så det inte propagerar ned till PlotView. -->
        <Border BackgroundColor="#E61A1A1A"
                StrokeThickness="0"
                Padding="0"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,0,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,10,10" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="0">
                <!-- Innehåll: Kväll N: + spelarkolumner. IsVisible bundet
                     till IsLegendExpanded — när false läggs HSL ut med
                     bredd 0 (Maui behandlar IsVisible=false som "gone")
                     och Border:n krymper till bara flikens höjd. -->
                <HorizontalStackLayout Spacing="10"
                                       Padding="14,10,14,6"
                                       IsVisible="{Binding IsLegendExpanded}">
                    <!-- VerticalOptions="End" + Padding bottom=2 matchar
                         items egna 2 dp bottom-padding så rubriken hamnar
                         på samma baslinje som snittsiffrorna. -->
                    <Label Text="{Binding SelectedNightLabel, StringFormat='{0}:'}"
                           TextColor="White"
                           FontFamily="Baloo2Bold"
                           FontSize="13"
                           VerticalOptions="End"
                           Padding="0,0,0,2"
                           IsVisible="{Binding HasSelectedNight}" />

                    <!-- BindableLayout istället för CollectionView: HSL+
                         CollectionView rapporterar inte DesiredSize
                         tillförlitligt i MAUI. Vi har alltid 4 spelare så
                         virtualisering ger inget. Ordning kommer från
                         LegendItems → PlotModel.Series → activePlayers
                         sorterade på DisplayOrder = Claes/Aleksi/Jonas/Robin. -->
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding LegendItems}"
                                           Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlayerLegendItem">
                                <Grid Padding="10,2" RowDefinitions="Auto,Auto" RowSpacing="2">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <HorizontalStackLayout Grid.Row="0" Spacing="5" HorizontalOptions="Center">
                                        <!-- BoxView med CornerRadius=5 på 10×10 = filled cirkel.
                                             Färg = spelarens färg (samma som linjen i grafen). -->
                                        <BoxView WidthRequest="10"
                                                 HeightRequest="10"
                                                 CornerRadius="5"
                                                 Color="{Binding Color}"
                                                 VerticalOptions="Center"
                                                 Opacity="{Binding NameOpacity}" />
                                        <Label Text="{Binding Name}"
                                               FontFamily="Baloo2Bold"
                                               FontSize="13"
                                               TextColor="{Binding Color}"
                                               VerticalOptions="Center"
                                               Opacity="{Binding NameOpacity}"
                                               TextDecorations="{Binding NameDecorations}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1"
                                           Text="{Binding NightAverageDisplay}"
                                           HorizontalOptions="Center"
                                           FontFamily="Baloo2Bold"
                                           FontSize="13"
                                           TextColor="White"
                                           Opacity="{Binding NameOpacity}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <!-- Collapse-flik: alltid synlig, ytterligare plattad
                     (FontSize 12→10, vertikal Padding 1/3→0/2 → tab ~12 dp
                     hög, ner från ~16 dp). PlotModel.Padding-topp är 32 dp
                     så flikens ~12 dp lämnar ~20 dp luft ner till titelns
                     översta baseline — "Kvällssnitt över tid" syns alltid
                     fullt ut när legend-rutan är ihopfälld. När den fälls
                     ut växer Border:n ner och täcker titeln (per spec).
                     Horisontell Padding bevarad (24 dp) så tap-target inte
                     krymper för mycket på bredden trots smalare höjd. -->
                <Label Text="{Binding LegendCollapseArrow}"
                       TextColor="White"
                       FontFamily="Baloo2Bold"
                       FontSize="10"
                       HorizontalOptions="Center"
                       Padding="24,0,24,2">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleLegendCollapseCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
