<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:vws="clr-namespace:DoubleDashScore.Views"
             x:Class="DoubleDashScore.Views.RoundEntryPage"
             x:DataType="vm:RoundEntryViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <vws:RoundMatrixView Players="{Binding Players}"
                                 TrackCountText="{Binding TrackCountText, Mode=TwoWay}" />

            <Label Text="{Binding ValidationMessage}" FontSize="13" TextColor="{AppThemeBinding Light=#B45309, Dark=#FBBF24}" />

            <HorizontalStackLayout Spacing="12" HorizontalOptions="End" Margin="0,8,0,0">
                <Button Text="Avbryt" Command="{Binding CancelCommand}" />
                <Button Text="Spara" Command="{Binding SaveCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
