<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:views="clr-namespace:DoubleDashScore.Views"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.HistoryStatsPage"
             x:Name="PageRoot"
             x:DataType="vm:HistoryStatsViewModel"
             Title="Statistik">

    <ContentPage.ToolbarItems>
        <!-- Översikt-sida (Skiva 18) — staplar/grid-symbolen valdes
             eftersom sidan listar Totalscore + senaste kvällarnas
             placeringar (en sammanfattningsvy, inte en delningsknapp).
             Text-fallback om ikonen inte renderas på en Android-version. -->
        <ToolbarItem Text="📊"
                     Order="Primary"
                     Priority="0"
                     Command="{Binding OpenOversiktCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Tab header: 4 tabbar i Skiva 16. Tab-namnen kortades till
             "Kvällsgraf"/"Karriärgraf" (från "Graf"/"Graf (kväll)"-mer-
             beskrivande varianter) för att rymmas på smal portrait-skärm
             (~360 dp / 4 ≈ 90 dp per tab). "Graf (karriär)" hade klippts. -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*" Padding="0,8,0,0">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Totalscore"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="0" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsTotalsTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="Placeringar"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="1" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsPlacementsTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" Spacing="4">
                <Label Text="Kvällsgraf"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="2" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsNightGraphTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" Spacing="4">
                <Label Text="Karriärgraf"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="3" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsCareerGraphTab}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Busy + status -->
        <VerticalStackLayout Grid.Row="1" Padding="16,8,16,0" Spacing="8">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                   FontSize="14"
                   Opacity="0.8" />
        </VerticalStackLayout>

        <!-- Tab content -->
        <Grid Grid.Row="2" Padding="16,8" IsVisible="{Binding HasData}">

            <!-- Totalscore — renderingen lyft ut till TotalscoreTable som
                 ContentView i Skiva 18 så att OversiktPage kan återanvända
                 samma visning. -->
            <views:TotalscoreTable IsVisible="{Binding IsTotalsTab}"
                                   ItemsSource="{Binding Totals}"
                                   IsCareerVisible="{Binding IsCareerAverageVisible}"
                                   ToggleLabel="{Binding CareerAverageToggleLabel}"
                                   ToggleCommand="{Binding ToggleCareerAverageCommand}" />

            <!-- Kvällsgraf — varje kvälls eget kvällssnitt per spelare. -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsNightGraphTab}">
                <Grid Grid.Row="0">
                    <!-- DefaultTrackerTemplate=null så OxyPlot.Maui.Skia inte
                         ritar sin gula tooltip vid tap på en datapunkt.
                         Tom ControlTemplate kraschar (ShowTracker castar
                         CreateContent()→View med NullRef); explicit null
                         hoppar PlotView över rendering helt. PlotModel.
                         TrackerChanged fires fortfarande, så VM:n får
                         notifikationen om vald kväll. Vår vertikala
                         LineAnnotation + legend-snitten ersätter trackern. -->
                    <oxy:PlotView Model="{Binding PlotModel}"
                                  BackgroundColor="Transparent"
                                  DefaultTrackerTemplate="{x:Null}" />
                    <Button Text="⛶ Helskärm"
                            Command="{Binding OpenFullScreenNightChartCommand}"
                            FontSize="12"
                            Padding="10,4"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,4,4,0" />
                </Grid>

                <!-- Legend med snitt: namn-rad orörd (color + name). "Kväll N"-
                     rubriken hänger direkt vänster om första snittsiffran (8 dp
                     gap), och hela gruppen centreras horisontellt så landskap
                     bara ger mer luft runt om — inte ett växande glapp mellan
                     rubrik och första siffran. BindableLayout istället för
                     CollectionView eftersom HSL+CollectionView (HorizontalList)
                     inte rapporterar DesiredSize tillförlitligt; vi har alltid
                     4 spelare så virtualisering ger inget. Tap på spelare
                     togglar synlighet; tap på en datapunkt i grafen uppdaterar
                     snittsiffrorna via TrackerChanged. -->
                <HorizontalStackLayout Grid.Row="1"
                                       HorizontalOptions="Center"
                                       Spacing="8"
                                       Margin="0,4,0,0">
                    <Label Text="{Binding SelectedNightLabel, StringFormat='{0}:'}"
                           FontFamily="Baloo2Bold"
                           FontSize="12"
                           VerticalOptions="End"
                           Padding="0,0,0,4"
                           IsVisible="{Binding HasSelectedNight}" />

                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding LegendItems}"
                                           Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlayerLegendItem">
                                <Grid Padding="8,4" RowDefinitions="Auto,Auto" RowSpacing="2">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <HorizontalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center">
                                        <BoxView WidthRequest="14"
                                                 HeightRequest="14"
                                                 Color="{Binding Color}"
                                                 VerticalOptions="Center"
                                                 Opacity="{Binding NameOpacity}" />
                                        <Label Text="{Binding Name}"
                                               FontFamily="Baloo2"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               Opacity="{Binding NameOpacity}"
                                               TextDecorations="{Binding NameDecorations}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1"
                                           Text="{Binding NightAverageDisplay}"
                                           HorizontalOptions="Center"
                                           FontFamily="Baloo2Bold"
                                           FontSize="13"
                                           Opacity="{Binding NameOpacity}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </Grid>

            <!-- Karriärgraf — löpande karriärsnitt per spelare (kumulativt
                 medel av kvällssnitten t.o.m. respektive kväll). Strukturen
                 är en klon av kvällsgrafen ovan med separata bindings:
                 CareerPlotModel, OpenFullScreenCareerChartCommand, Career-
                 LegendItems. TogglePlayerVisibilityCommand är gemensam
                 (togglar samtidigt i båda graferna via store:n). -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsCareerGraphTab}">
                <Grid Grid.Row="0">
                    <oxy:PlotView Model="{Binding CareerPlotModel}"
                                  BackgroundColor="Transparent"
                                  DefaultTrackerTemplate="{x:Null}" />
                    <Button Text="⛶ Helskärm"
                            Command="{Binding OpenFullScreenCareerChartCommand}"
                            FontSize="12"
                            Padding="10,4"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,4,4,0" />
                </Grid>

                <HorizontalStackLayout Grid.Row="1"
                                       HorizontalOptions="Center"
                                       Spacing="8"
                                       Margin="0,4,0,0">
                    <Label Text="{Binding SelectedNightLabel, StringFormat='{0}:'}"
                           FontFamily="Baloo2Bold"
                           FontSize="12"
                           VerticalOptions="End"
                           Padding="0,0,0,4"
                           IsVisible="{Binding HasSelectedNight}" />

                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding CareerLegendItems}"
                                           Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlayerLegendItem">
                                <Grid Padding="8,4" RowDefinitions="Auto,Auto" RowSpacing="2">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <HorizontalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center">
                                        <BoxView WidthRequest="14"
                                                 HeightRequest="14"
                                                 Color="{Binding Color}"
                                                 VerticalOptions="Center"
                                                 Opacity="{Binding NameOpacity}" />
                                        <Label Text="{Binding Name}"
                                               FontFamily="Baloo2"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               Opacity="{Binding NameOpacity}"
                                               TextDecorations="{Binding NameDecorations}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1"
                                           Text="{Binding NightAverageDisplay}"
                                           HorizontalOptions="Center"
                                           FontFamily="Baloo2Bold"
                                           FontSize="13"
                                           Opacity="{Binding NameOpacity}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </Grid>

            <!-- Placeringar — flat tabell (Kväll + 4 spelarkolumner, en
                 rad per kväll). Renderingen lyftes ut till PlacementsTable
                 i Skiva 18 så att Översikt-sidan kan plocka samma tabell
                 filtrerad till de 4 senaste kvällarna. -->
            <views:PlacementsTable x:Name="PlacementsTableView"
                                   IsVisible="{Binding IsPlacementsTab}"
                                   ItemsSource="{Binding PlacementsRows}"
                                   Headers="{Binding PlacementsHeaders}" />
        </Grid>
    </Grid>
</ContentPage>
