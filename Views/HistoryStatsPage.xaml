<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.HistoryStatsPage"
             x:Name="PageRoot"
             x:DataType="vm:HistoryStatsViewModel"
             Title="Statistik">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Tab header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" Padding="0,8,0,0">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Totalscore"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="0" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsTotalsTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="Placeringar"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="1" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsPlacementsTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" Spacing="4">
                <Label Text="Graf"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="2" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{StaticResource Primary}"
                         IsVisible="{Binding IsGraphTab}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Busy + status -->
        <VerticalStackLayout Grid.Row="1" Padding="16,8,16,0" Spacing="8">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                   FontSize="14"
                   Opacity="0.8" />
        </VerticalStackLayout>

        <!-- Tab content -->
        <Grid Grid.Row="2" Padding="16,8" IsVisible="{Binding HasData}">

            <!-- Totalscore -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsTotalsTab}">
                <!-- Toggle-länken sitter ovanför listan (option C) i stället för
                     bredvid kolumn-rubriken. Det låter Karriärsnitt-kolumnen behålla
                     sin ursprungliga bredd (72 dp) så Spelare-kolumnen får plats för
                     "Aleksi" utan klippning, och rubrikraden hålls på en rad. -->
                <Label Text="{Binding CareerAverageToggleLabel}"
                       TextColor="{StaticResource Primary}"
                       FontFamily="Baloo2Bold"
                       FontSize="13"
                       HorizontalOptions="End"
                       Padding="8,4">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCareerAverageCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Grid ColumnDefinitions="*,40,40,40,40,72"
                      Padding="0,4"
                      ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Spelare" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                    <Label Grid.Column="1" Text="1:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="2" Text="2:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="3" Text="3:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="4" Text="4:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="5"
                           Text="Karriärsnitt"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           LineBreakMode="TailTruncation" />
                </Grid>
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}" />
                <CollectionView ItemsSource="{Binding Totals}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TotalsRow">
                            <Grid ColumnDefinitions="*,40,40,40,40,72"
                                  Padding="0,6"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0" Text="{Binding PlayerName}" LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1" Text="{Binding Firsts}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="2" Text="{Binding Seconds}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="3" Text="{Binding Thirds}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="4" Text="{Binding Fourths}" HorizontalTextAlignment="End" />
                                <!-- Två överlagrade labels: värdet visas när togglen är på,
                                     "•••"-platshållaren när den är av. IsVisible binds till
                                     sidans VM via PageRoot eftersom row:ens BindingContext
                                     är TotalsRow, inte HistoryStatsViewModel. -->
                                <Label Grid.Column="5"
                                       Text="{Binding CareerAverage}"
                                       HorizontalTextAlignment="End"
                                       IsVisible="{Binding Source={x:Reference PageRoot}, Path=BindingContext.IsCareerAverageVisible}" />
                                <Label Grid.Column="5"
                                       Text="•••"
                                       HorizontalTextAlignment="End"
                                       Opacity="0.5"
                                       IsVisible="{Binding Source={x:Reference PageRoot}, Path=BindingContext.IsCareerAverageVisible, Converter={StaticResource InvertedBoolConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Graf -->
            <Grid RowDefinitions="*,Auto,Auto,Auto" IsVisible="{Binding IsGraphTab}">
                <Grid Grid.Row="0">
                    <oxy:PlotView Model="{Binding PlotModel}"
                                  BackgroundColor="Transparent"
                                  DefaultTrackerTemplate="{StaticResource DarkChartTracker}" />
                    <Button Text="⛶ Helskärm"
                            Command="{Binding OpenFullScreenChartCommand}"
                            FontSize="12"
                            Padding="10,4"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,4,4,0" />
                </Grid>

                <!-- Scrubber-panel: alla fyra spelares kvällssnitt för vald
                     kväll, sorterat bäst→sämst. Mörkgrå bg + vit text matchar
                     punkt-tooltipens stil (DarkChartTracker i App.xaml). -->
                <Border Grid.Row="1"
                        StrokeThickness="0"
                        BackgroundColor="#2A2A2A"
                        Padding="14,10"
                        Margin="0,6,0,0"
                        IsVisible="{Binding HasSelectedNightSlice}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding SelectedNightSlice.DateLabel}"
                               TextColor="White"
                               FontFamily="Baloo2Bold"
                               FontSize="14" />
                        <CollectionView ItemsSource="{Binding SelectedNightSlice.RowsBestToWorst}"
                                        SelectionMode="None"
                                        Margin="0,2,0,0">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlayerNightAverageRow">
                                    <Grid ColumnDefinitions="14,*,Auto" ColumnSpacing="10" Padding="0,2">
                                        <BoxView Grid.Column="0"
                                                 Color="{Binding Color}"
                                                 WidthRequest="14"
                                                 HeightRequest="14"
                                                 VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding PlayerName}"
                                               TextColor="White"
                                               FontFamily="Baloo2"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="2"
                                               Text="{Binding AverageDisplay}"
                                               TextColor="White"
                                               FontFamily="Baloo2Bold"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Slider under panelen. Snäpper till heltal via VM:s
                     OnScrubberValueChanged. Döljs när det bara finns en kväll
                     (Min == Max gör slidern oanvändbar). -->
                <Slider Grid.Row="2"
                        Minimum="0"
                        Maximum="{Binding ScrubberMaximum}"
                        Value="{Binding ScrubberValue, Mode=TwoWay}"
                        MinimumTrackColor="{StaticResource Primary}"
                        MaximumTrackColor="{StaticResource Gray400}"
                        ThumbColor="{StaticResource Primary}"
                        IsVisible="{Binding IsScrubberSliderEnabled}"
                        Margin="0,6,0,0" />

                <!-- Egen legend: tap på en spelare döljer/visar dess linje. -->
                <CollectionView Grid.Row="3"
                                ItemsSource="{Binding LegendItems}"
                                ItemsLayout="HorizontalList"
                                SelectionMode="None"
                                HeightRequest="36"
                                HorizontalOptions="Center"
                                Margin="0,4,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlayerLegendItem">
                            <Grid Padding="10,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.TogglePlayerVisibilityCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <BoxView WidthRequest="14"
                                             HeightRequest="14"
                                             Color="{Binding Color}"
                                             VerticalOptions="Center"
                                             Opacity="{Binding NameOpacity}" />
                                    <Label Text="{Binding Name}"
                                           FontFamily="Baloo2"
                                           FontSize="13"
                                           VerticalOptions="Center"
                                           Opacity="{Binding NameOpacity}"
                                           TextDecorations="{Binding NameDecorations}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Placeringar -->
            <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding IsPlacementsTab}">
                <Grid Grid.Row="0"
                      ColumnDefinitions="80,*,*,*,*"
                      Padding="0,4"
                      ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Kväll" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding PlacementsHeaders.Player1}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="2" Text="{Binding PlacementsHeaders.Player2}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="3" Text="{Binding PlacementsHeaders.Player3}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="4" Text="{Binding PlacementsHeaders.Player4}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                </Grid>
                <BoxView Grid.Row="1" HeightRequest="1" Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}" />
                <CollectionView Grid.Row="2"
                                x:Name="PlacementsCollectionView"
                                ItemsSource="{Binding PlacementsRows}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlacementsRow">
                            <Grid ColumnDefinitions="80,*,*,*,*"
                                  Padding="0,6"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0" Text="{Binding NightLabel}" />
                                <Label Grid.Column="1" Text="{Binding Player1}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="2" Text="{Binding Player2}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="3" Text="{Binding Player3}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="4" Text="{Binding Player4}" HorizontalTextAlignment="End" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
