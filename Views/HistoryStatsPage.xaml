<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:oxy="clr-namespace:OxyPlot.Maui.Skia;assembly=OxyPlot.Maui.Skia"
             x:Class="DoubleDashScore.Views.HistoryStatsPage"
             x:DataType="vm:HistoryStatsViewModel"
             Title="Statistik">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Tab header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" Padding="0,8,0,0">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Totalscore"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="0" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{AppThemeBinding Light=#4E9CFF, Dark=#4E9CFF}"
                         IsVisible="{Binding IsTotalsTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="Kvällssnitt"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="1" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{AppThemeBinding Light=#4E9CFF, Dark=#4E9CFF}"
                         IsVisible="{Binding IsGraphTab}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" Spacing="4">
                <Label Text="Placeringar"
                       HorizontalTextAlignment="Center"
                       Padding="8"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="2" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2"
                         Color="{AppThemeBinding Light=#4E9CFF, Dark=#4E9CFF}"
                         IsVisible="{Binding IsPlacementsTab}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Busy + status -->
        <VerticalStackLayout Grid.Row="1" Padding="16,8,16,0" Spacing="8">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                   FontSize="14"
                   Opacity="0.8" />
        </VerticalStackLayout>

        <!-- Tab content -->
        <Grid Grid.Row="2" Padding="16,8" IsVisible="{Binding HasData}">

            <!-- Totalscore -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsTotalsTab}">
                <Grid ColumnDefinitions="*,40,40,40,40,72"
                      Padding="0,4"
                      ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Spelare" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                    <Label Grid.Column="1" Text="1:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="2" Text="2:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="3" Text="3:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="4" Text="4:or" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="5"
                           Text="Karriär&#10;snitt"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           LineBreakMode="WordWrap" />
                </Grid>
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}" />
                <CollectionView ItemsSource="{Binding Totals}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TotalsRow">
                            <Grid ColumnDefinitions="*,40,40,40,40,72"
                                  Padding="0,6"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0" Text="{Binding PlayerName}" LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1" Text="{Binding Firsts}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="2" Text="{Binding Seconds}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="3" Text="{Binding Thirds}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="4" Text="{Binding Fourths}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="5" Text="{Binding CareerAverage}" HorizontalTextAlignment="End" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Kvällssnitt graf -->
            <Grid IsVisible="{Binding IsGraphTab}">
                <oxy:PlotView Model="{Binding PlotModel}"
                              BackgroundColor="Transparent" />
                <Button Text="⛶ Helskärm"
                        Command="{Binding OpenFullScreenChartCommand}"
                        FontSize="12"
                        Padding="10,4"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        Margin="0,4,4,0" />
            </Grid>

            <!-- Placeringar -->
            <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding IsPlacementsTab}">
                <Grid Grid.Row="0"
                      ColumnDefinitions="80,*,*,*,*"
                      Padding="0,4"
                      ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Kväll" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding PlacementsHeaders.Player1}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="2" Text="{Binding PlacementsHeaders.Player2}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="3" Text="{Binding PlacementsHeaders.Player3}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    <Label Grid.Column="4" Text="{Binding PlacementsHeaders.Player4}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                </Grid>
                <BoxView Grid.Row="1" HeightRequest="1" Color="{AppThemeBinding Light=#DDDDDD, Dark=#444444}" />
                <CollectionView Grid.Row="2"
                                x:Name="PlacementsCollectionView"
                                ItemsSource="{Binding PlacementsRows}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlacementsRow">
                            <Grid ColumnDefinitions="80,*,*,*,*"
                                  Padding="0,6"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0" Text="{Binding NightLabel}" />
                                <Label Grid.Column="1" Text="{Binding Player1}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="2" Text="{Binding Player2}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="3" Text="{Binding Player3}" HorizontalTextAlignment="End" />
                                <Label Grid.Column="4" Text="{Binding Player4}" HorizontalTextAlignment="End" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
