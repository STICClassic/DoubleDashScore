<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             x:Class="DoubleDashScore.Views.RestoreAutoBackupPage"
             x:Name="PageRoot"
             x:DataType="vm:RestoreAutoBackupViewModel"
             Title="Återställ från auto-backup"
             BackgroundColor="{StaticResource OffBlack}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="14">

        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="Återställ från auto-backup"
                   TextColor="{StaticResource White}"
                   FontFamily="Baloo2Bold"
                   FontSize="22" />
            <Label Text="Tryck på en backup för att återställa databasen till det läget. Det nuvarande läget säkerhetskopieras innan ändring."
                   TextColor="{StaticResource Gray200}"
                   FontSize="13" />
        </VerticalStackLayout>

        <Label Grid.Row="1"
               Text="Inga auto-backups än. De skapas automatiskt när du ändrar något i databasen."
               TextColor="{StaticResource Gray200}"
               FontSize="14"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Padding="20"
               IsVisible="{Binding IsEmpty}" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:BackupItem">
                    <Grid Padding="0,2">
                        <Border Stroke="{StaticResource Gray600}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource Gray900}"
                                Padding="16,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.RestoreCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding TimestampLabel}"
                                   TextColor="{StaticResource White}"
                                   FontFamily="Baloo2"
                                   FontSize="16" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <ActivityIndicator Grid.Column="0"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Start"
                               VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Stäng"
                    Command="{Binding CloseCommand}"
                    BackgroundColor="{StaticResource Gray600}"
                    TextColor="{StaticResource White}" />
        </Grid>

    </Grid>
</ContentPage>
