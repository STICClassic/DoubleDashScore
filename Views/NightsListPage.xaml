<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="DoubleDashScore.Views.NightsListPage"
             x:Name="PageRoot"
             x:DataType="vm:NightsListViewModel"
             Title="Kvällar">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16,12">

        <!-- Prominent primär-action: ersätter den gömda "Ny kväll"-toolbar-
             länken. Samma NewNightCommand som tidigare. -->
        <Button Grid.Row="0"
                Text="＋  Lägg till ny kväll"
                BackgroundColor="{StaticResource Primary}"
                TextColor="Black"
                FontFamily="Baloo2Bold"
                FontSize="16"
                CornerRadius="12"
                HeightRequest="52"
                Command="{Binding NewNightCommand}" />

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           Margin="0,12" />

        <Label Grid.Row="2"
               Text="Inga kvällar än. Tryck på 'Lägg till ny kväll' för att börja."
               TextColor="{StaticResource Gray300}"
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Padding="20" />

        <CollectionView Grid.Row="2"
                        Margin="0,12,0,0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:NightListItem">
                    <Border BackgroundColor="#0DFFFFFF"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            Padding="16,12">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenNightCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="4">
                            <!-- Översta raden: datum vänster, antal omgångar höger. -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Date}"
                                       FontFamily="Baloo2Bold"
                                       TextColor="White"
                                       FontSize="16" />
                                <Label Grid.Column="1"
                                       Text="{Binding RoundsSummary}"
                                       TextColor="{StaticResource Gray300}"
                                       FontSize="13"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Anteckning (endast om kvällen har en). -->
                            <Label Text="{Binding Note}"
                                   TextColor="{StaticResource Gray300}"
                                   FontSize="13"
                                   IsVisible="{Binding Note, Converter={StaticResource StringNotEmptyConverter}}" />

                            <!-- Vinnare per omgång (färgade spans) + trash-ikon. -->
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                <Label Grid.Column="0"
                                       FormattedText="{Binding Winners}"
                                       FontSize="14"
                                       LineBreakMode="WordWrap"
                                       VerticalOptions="Center" />

                                <!-- Demoterad radera-action: liten dämpad papperskorg. -->
                                <ContentView Grid.Column="1"
                                             Padding="10,2,0,2"
                                             VerticalOptions="Center">
                                    <ContentView.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteNightCommand}"
                                            CommandParameter="{Binding .}" />
                                    </ContentView.GestureRecognizers>
                                    <shapes:Path Fill="#59FFFFFF"
                                                 HeightRequest="20"
                                                 WidthRequest="20"
                                                 Aspect="Uniform"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Data="M9 3V4H4V6H5V19A2 2 0 0 0 7 21H17A2 2 0 0 0 19 19V6H20V4H15V3H9M7 6H17V19H7V6M9 8V17H11V8H9M13 8V17H15V8H13Z" />
                                </ContentView>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
