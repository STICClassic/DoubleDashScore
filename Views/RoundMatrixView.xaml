<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoubleDashScore.Views.RoundMatrixView"
             x:Name="Root">

    <VerticalStackLayout Spacing="14">

        <Grid ColumnDefinitions="*,120" ColumnSpacing="12" VerticalOptions="Center">
            <Label Grid.Column="0" Text="Antal banor" VerticalOptions="Center" />
            <Entry Grid.Column="1"
                   Text="{Binding TrackCountText, Source={x:Reference Root}, Mode=TwoWay}"
                   Keyboard="Numeric"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <Label Text="Räknare per spelare" FontAttributes="Bold" Margin="0,8,0,0" />

        <Grid ColumnDefinitions="64,*,*,*,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="6"
              ColumnSpacing="8">

            <Label Grid.Row="0" Grid.Column="0" Text="" />

            <Label Grid.Row="0" Grid.Column="1"
                   Text="{Binding Players[0].PlayerName, Source={x:Reference Root}}"
                   FontAttributes="Bold" HorizontalTextAlignment="Center"
                   IsVisible="{Binding ColumnHeader0, Source={x:Reference Root}, Converter={StaticResource IsNullConverter}}" />
            <ContentView Grid.Row="0" Grid.Column="1"
                         Content="{Binding ColumnHeader0, Source={x:Reference Root}}" />

            <Label Grid.Row="0" Grid.Column="2"
                   Text="{Binding Players[1].PlayerName, Source={x:Reference Root}}"
                   FontAttributes="Bold" HorizontalTextAlignment="Center"
                   IsVisible="{Binding ColumnHeader1, Source={x:Reference Root}, Converter={StaticResource IsNullConverter}}" />
            <ContentView Grid.Row="0" Grid.Column="2"
                         Content="{Binding ColumnHeader1, Source={x:Reference Root}}" />

            <Label Grid.Row="0" Grid.Column="3"
                   Text="{Binding Players[2].PlayerName, Source={x:Reference Root}}"
                   FontAttributes="Bold" HorizontalTextAlignment="Center"
                   IsVisible="{Binding ColumnHeader2, Source={x:Reference Root}, Converter={StaticResource IsNullConverter}}" />
            <ContentView Grid.Row="0" Grid.Column="3"
                         Content="{Binding ColumnHeader2, Source={x:Reference Root}}" />

            <Label Grid.Row="0" Grid.Column="4"
                   Text="{Binding Players[3].PlayerName, Source={x:Reference Root}}"
                   FontAttributes="Bold" HorizontalTextAlignment="Center"
                   IsVisible="{Binding ColumnHeader3, Source={x:Reference Root}, Converter={StaticResource IsNullConverter}}" />
            <ContentView Grid.Row="0" Grid.Column="4"
                         Content="{Binding ColumnHeader3, Source={x:Reference Root}}" />

            <Label Grid.Row="1" Grid.Column="0" Text="1:or" VerticalOptions="Center" />
            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Players[0].FirstPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="1" Grid.Column="2" Text="{Binding Players[1].FirstPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="1" Grid.Column="3" Text="{Binding Players[2].FirstPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="1" Grid.Column="4" Text="{Binding Players[3].FirstPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />

            <Label Grid.Row="2" Grid.Column="0" Text="2:or" VerticalOptions="Center" />
            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Players[0].SecondPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="2" Grid.Column="2" Text="{Binding Players[1].SecondPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="2" Grid.Column="3" Text="{Binding Players[2].SecondPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="2" Grid.Column="4" Text="{Binding Players[3].SecondPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />

            <Label Grid.Row="3" Grid.Column="0" Text="3:or" VerticalOptions="Center" />
            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Players[0].ThirdPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="3" Grid.Column="2" Text="{Binding Players[1].ThirdPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="3" Grid.Column="3" Text="{Binding Players[2].ThirdPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="3" Grid.Column="4" Text="{Binding Players[3].ThirdPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />

            <Label Grid.Row="4" Grid.Column="0" Text="4:or" VerticalOptions="Center" />
            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Players[0].FourthPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="4" Grid.Column="2" Text="{Binding Players[1].FourthPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="4" Grid.Column="3" Text="{Binding Players[2].FourthPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
            <Entry Grid.Row="4" Grid.Column="4" Text="{Binding Players[3].FourthPlacesText, Source={x:Reference Root}, Mode=TwoWay}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
        </Grid>
    </VerticalStackLayout>
</ContentView>
