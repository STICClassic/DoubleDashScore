<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DoubleDashScore.ViewModels"
             x:Class="DoubleDashScore.Views.PlayerEditPage"
             x:DataType="vm:PlayerEditViewModel"
             Title="Spelare">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Redigera de fyra spelarnas namn." FontSize="13" Opacity="0.8" />

            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlayerEditItem">
                        <Grid Padding="0,8" ColumnDefinitions="*">
                            <Entry Text="{Binding Name}" Placeholder="Namn" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout Spacing="12" HorizontalOptions="End" Margin="0,8,0,0">
                <Button Text="Avbryt" Command="{Binding CancelCommand}" />
                <Button Text="Spara" Command="{Binding SaveCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
