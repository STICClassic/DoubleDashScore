<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Skiva 6b: överskugga MAUI:s default Maui.MainTheme så att statusbar inte
         följer colorPrimary (= orange #FB923C) efter att splash:en lämnat över.
         MAUI:s default sätter android:statusBarColor till ?attr/colorPrimaryVariant
         (= colorPrimaryDark = #1F1F1F i 6a:s colors.xml), men där har vi sett att
         splash:ens orange dröjer kvar tills runtime-koden hinner sätta färgen. Sätter
         vi en literal #1F1F1F i temat kommer det att gälla från frame 0 efter splash.

         Vi rör inte Maui.SplashTheme — den refererar till MAUI-genererade resurser
         (drawable/splash_screen, attr/postSplashScreenTheme) som inte är synliga här,
         och splash:ens egen orange bakgrund vill vi behålla. Statusbar under splash
         är kortvarig och hanteras dessutom av runtime-koden i MainActivity.OnCreate. -->

    <style name="Maui.MainTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="android:statusBarColor">#FF1F1F1F</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
